{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/research",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/research/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/research-capability",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/research-capability/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/discover-research",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/discover-research/",
      "destination": "/",
      "permanent": true
    }
  ]
}
