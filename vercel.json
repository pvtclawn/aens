{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "bun install && cd app && bun install",
  "buildCommand": "cd app && bun run build",
  "outputDirectory": "app/dist",
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/research-capability",
      "destination": "/research-capability/index.html"
    },
    {
      "source": "/research-capability/",
      "destination": "/research-capability/index.html"
    },
    {
      "source": "/discover-research",
      "destination": "/discover-research/index.html"
    },
    {
      "source": "/discover-research/",
      "destination": "/discover-research/index.html"
    }
  ]
}
