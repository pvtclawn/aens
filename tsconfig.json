{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": false,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts"]
}
